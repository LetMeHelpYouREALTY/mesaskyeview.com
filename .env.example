# =============================================================================
# mesaskyeview.com / multi-domain BHHS site — environment variables
# Copy to .env.local for local dev, or sync from Vercel: vercel env pull .env.local
# =============================================================================

# --- Site (public) ---
# Canonical host (Vercel: apex mesaskyeview.com → 308 → www)
NEXT_PUBLIC_SITE_URL=https://www.mesaskyeview.com

# Google Search Console — HTML tag method: paste ONLY the content= token (not the full meta tag)
GOOGLE_SITE_VERIFICATION=
# Domain-specific contact email is in lib/domain-config.ts (mesaskyeview.com)

# --- Already wired in code ---
OPENROUTER_API_KEY=
# Vercel name → code alias in lib/env.ts:
FOLLOW_UP_BOSS_API_KEY=
# Optional duplicate if you prefer legacy name:
# FUB_API_KEY=
FUB_SYSTEM_KEY=

# Google Analytics 4 (layout loads gtag when set)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Vercel Analytics (no key; enabled in app/layout.tsx) ---

# --- Cloudinary (images; add res.cloudinary.com to next/image remotePatterns) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=

# --- Google Maps (optional; office map currently uses free embed iframe) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Notion (future logging/CMS; lib/env.ts reads NOTION_TOKEN) ---
NOTION_TOKEN=

# --- v0.dev API (design tooling; not required for production runtime) ---
V0_API_KEY=

# --- Cloudflare (Workers/deploy automation; not required for Vercel-only deploy) ---
CLOUDFLARE_API_TOKEN=
# Optional: full Cloudflare Images URL if headshot is on imagedelivery.net (overrides /Image/agent1.jpg)
# NEXT_PUBLIC_DR_JAN_DUFFY_HEADSHOT=https://imagedelivery.net/<account-hash>/<image-id>/public

# --- Optional integrations (see .env.*.example in repo) ---
# ANTHROPIC_API_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# mesaskyeview.com lead email: DrDuffySells@MesaSkyeview.com (lib/domain-config.ts)
